# ─────────────────────────────────────────────────────────────
#  Variables de entorno — Módulo de Citas (Renoveplac)
#  Copia este archivo a .env.local y rellena tus propios valores.
#  Ningún valor real se incluye aquí.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
SUPABASE_URL=<<TU_SUPABASE_URL>>
SUPABASE_SERVICE_KEY=<<TU_SERVICE_ROLE_KEY>>

# Resend — envío de emails transaccionales (https://resend.com)
RESEND_API_KEY=<<TU_RESEND_KEY>>
# Remitente con dominio verificado. Si lo dejas vacío se usa onboarding@resend.dev
RESEND_FROM_EMAIL=Renoveplac <visitas@tudominio.com>

# Bandeja del equipo que recibe avisos de citas
ADMIN_EMAIL=tu-equipo@tudominio.com

# Cadena aleatoria larga para firmar la cookie de sesión (JWT)
JWT_SECRET=<<CADENA_ALEATORIA_LARGA>>

# Protege el endpoint del cron. Configúrala también en Vercel.
CRON_SECRET=<<CADENA_ALEATORIA>>

# URL pública de la app (para enlaces dentro de los emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
